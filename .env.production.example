# Copy to .env.production on the Pi and fill in real values.
# Used by `docker compose --env-file .env.production up -d`.

POSTGRES_PASSWORD=""

# Generate with: npx auth secret
AUTH_SECRET=""

# Optional Discord OAuth (leave blank to disable)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# No DOMAIN var here — the app container only binds to 127.0.0.1:3000.
# The public domain/TLS cert is handled by the host's own Caddy instance
# (system-level /etc/caddy/Caddyfile, outside this repo), not by Compose.
