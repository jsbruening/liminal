# Copy to .env.production on the Pi and fill in real values.
# Used by `docker compose --env-file .env.production up -d`.

POSTGRES_PASSWORD=""

# Generate with: npx auth secret
AUTH_SECRET=""

# Optional Discord OAuth (leave blank to disable)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Public hostname Caddy will request a Let's Encrypt cert for
# (e.g. liminal-jake.duckdns.org)
DOMAIN=""
